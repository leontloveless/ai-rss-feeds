{
  "name": "ai-rss-feeds",
  "version": "1.0.0",
  "description": "AI-powered RSS feed generator for blogs without RSS",
  "type": "module",
  "scripts": {
    "add": "bun run src/add-feed.ts",
    "update": "bun run src/run-all.ts",
    "update:one": "bun run src/run-all.ts --name",
    "validate": "bun run src/run-all.ts --validate-only",
    "heal": "bun run src/heal-feed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "feed": "^4.2.2",
    "rss-parser": "^3.13.0",
    "date-fns": "^4.1.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
